uint16_t CalculateCRC16(uint8_t *data, uint16_t length)
{
	uint16_t crc = 0xFFFF;
	for (uint16_t i = 0; i < length; i++)
	{
		crc = crc ^ data[i];
		for (uint8_t j = 0; j < 8; j++)
		{
			if (crc & 0x0001)
			{
				crc = crc >> 1;
				crc = crc^ 0xA001;
			}
			else
			{
				crc = crc >> 1;
			}
		}
	}
	return crc;
}

static void LCD_WriteCommand(uint8_t cmd) {
	uint8_t data[4];
	    uint8_t high_nibble = (cmd & 0xF0) | 0x08; // 0x08 turns on Backlight, RS=0
	    uint8_t low_nibble  = ((cmd << 4) & 0xF0) | 0x08;

	    data[0] = high_nibble | 0x04;  // EN=1
	    data[1] = high_nibble & ~0x04; // EN=0 (Latching the data)
	    data[2] = low_nibble | 0x04;   // EN=1
	    data[3] = low_nibble & ~0x04;  // EN=0 (Latching the data)

	    HAL_I2C_Master_Transmit(&hi2c1, LCD_ADDR << 1, data, 4, HAL_MAX_DELAY);
}

static void LCD_WriteData(uint8_t data_val) {
	uint8_t data[4];
	    uint8_t high_nibble = (data_val & 0xF0) | 0x08 | 0x01; // 0x08=Backlight, 0x01=RS(Data)
	    uint8_t low_nibble  = ((data_val << 4) & 0xF0) | 0x08 | 0x01;

	    data[0] = high_nibble | 0x04;  // EN=1
	    data[1] = high_nibble & ~0x04; // EN=0 (Latching the data)
	    data[2] = low_nibble | 0x04;   // EN=1
	    data[3] = low_nibble & ~0x04;  // EN=0 (Latching the data)

	    HAL_I2C_Master_Transmit(&hi2c1, LCD_ADDR << 1, data, 4, HAL_MAX_DELAY);
}
void LCD_Init(void) {
	HAL_Delay(50);
	    LCD_WriteCommand(0x33);
	    HAL_Delay(5);
	    LCD_WriteCommand(0x32);
	    HAL_Delay(5);
	    LCD_WriteCommand(0x28);
	    HAL_Delay(1);
	    LCD_WriteCommand(0x0C);
	    HAL_Delay(1);
	    LCD_WriteCommand(0x01);
	    HAL_Delay(5);

	    // THIS IS THE MAGIC COMMAND THAT STOPS SCROLLING
	    LCD_WriteCommand(0x06);
	    HAL_Delay(1);
}
void LCD_Clear(void) {
	LCD_WriteCommand(LCD_CLEARDISPLAY);
	HAL_Delay(2);
}
void LCD_SetCursor(uint8_t row, uint8_t col) {
	uint8_t address = (row == 0) ? 0x80 + col : 0xC0 + col;
	    LCD_WriteCommand(address);
	    HAL_Delay(2);
}
void LCD_Print(char *str) {
	while (*str) {
		LCD_WriteData(*str++);
	}
}
void UpdateDisplay(void) {
	char buffer[16];

	    LCD_Clear(); // Ensure your LCD_Clear function has a 5ms delay inside it!

	    // --- TOP ROW (First Line) ---
	    LCD_SetCursor(0, 0);
	    sprintf(buffer, "P:%d", holdingRegisters[REG_PRESSURE]);
	    LCD_Print(buffer);

	    LCD_SetCursor(0, 8);
	    sprintf(buffer, "F:%d", holdingRegisters[REG_FLOW]);
	    LCD_Print(buffer);

	    // --- BOTTOM ROW (Second Line) ---
	    LCD_SetCursor(1, 0);
	    sprintf(buffer, "T:%d", holdingRegisters[REG_TEMP]);
	    LCD_Print(buffer);

	    LCD_SetCursor(1, 8);
	    sprintf(buffer, "V:%d", coilState);
	    LCD_Print(buffer);
}

uint16_t Read_ADC(ADC_HandleTypeDef *hadc, uint32_t channel) {
	ADC_ChannelConfTypeDef sConfig = {0};
	sConfig.Channel = channel;
	sConfig.Rank = 1;
	sConfig.SamplingTime = ADC_SAMPLETIME_55CYCLES_5;
	HAL_ADC_ConfigChannel(hadc, &sConfig);

	uint16_t adcValue = 0;
	HAL_ADC_Start(hadc);
	if (HAL_ADC_PollForConversion(hadc, 10) == HAL_OK) {
		adcValue = HAL_ADC_GetValue(hadc);
	}
	HAL_ADC_Stop(hadc);
	return adcValue;
}

// --- Modbus RTU Slave ---
void Modbus_ProcessRequest(uint8_t *rxBuffer, uint8_t rxLength) {
	uint16_t crc = CalculateCRC16(rxBuffer, rxLength - 2);
	if (crc != *(uint16_t*)&rxBuffer[rxLength - 2]) {
		return; // Invalid CRC
	}

	uint8_t slaveAddr = rxBuffer[0];
	uint8_t funcCode = rxBuffer[1];

	if (slaveAddr != SLAVE_ADDRESS)
		return;

	if (funcCode == 0x03) { // Read Holding Registers
		uint16_t startReg = (rxBuffer[2] << 8) | rxBuffer[3];
		uint16_t regCount = (rxBuffer[4] << 8) | rxBuffer[5];
		uint8_t response[256];
		response[0] = slaveAddr;
		response[1] = funcCode;
		response[2] = regCount * 2; // Byte count
		for (int i = 0; i < regCount; i++) {
			response[3 + 2*i] = (holdingRegisters[startReg + i] >> 8) & 0xFF;
			response[4 + 2*i] = holdingRegisters[startReg + i] & 0xFF;
		}
		uint16_t crc = CalculateCRC16(response, 3 + regCount*2);
		response[3 + regCount*2] = crc & 0xFF;
		response[4 + regCount*2] = (crc >> 8) & 0xFF;
		HAL_UART_Transmit(&huart1, response, 5 + regCount*2, HAL_MAX_DELAY);
	}
	else if (funcCode == 0x06) { // Write Single Register
		uint16_t regAddr = (rxBuffer[2] << 8) | rxBuffer[3];
		holdingRegisters[regAddr] = (rxBuffer[4] << 8) | rxBuffer[5];
	}
	else if (funcCode == 0x05) { // Write Single Coil
		uint16_t coilAddr = (rxBuffer[2] << 8) | rxBuffer[3];
		coilState = rxBuffer[4];
	}
}

