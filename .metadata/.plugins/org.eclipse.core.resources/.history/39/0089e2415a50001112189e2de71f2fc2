  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_USART1_UART_Init();
  MX_I2C1_Init();

  /* USER CODE BEGIN 2 */
//	MX_USART1_UART_Init();
	//MX_I2C1_Init();
  printf("STM32 Modbus Slave Starting...\r\n");
	LCD_Init();
	holdingRegisters[REG_HI_ALARM_P] = 3600; // 360 bar
	holdingRegisters[REG_HI_ALARM_F] = 900;  // 900 L/min
	holdingRegisters[REG_HI_ALARM_T] = 1200; // 120°C
	HAL_ADCEx_Calibration_Start(&hadc1);
	uint32_t last_lcd_update = 0;
	uint8_t last_button_state = GPIO_PIN_RESET;
	/* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
	while (1)
	{
	    // FR-01: Read Analog Channels
	    uint16_t raw_p = Read_ADC(&hadc1, ADC_CHANNEL_0);
	    uint16_t raw_f = Read_ADC(&hadc1, ADC_CHANNEL_1);
	    uint16_t raw_t = Read_ADC(&hadc1, ADC_CHANNEL_2);

	    // FR-02/03/04: Apply Scaling (Engineering Units x 10)
	    holdingRegisters[REG_PRESSURE] = (uint16_t)((raw_p / 4095.0) * 4000);
	    holdingRegisters[REG_FLOW]     = (uint16_t)((raw_f / 4095.0) * 10000);
	    holdingRegisters[REG_TEMP]     = (uint16_t)((raw_t / 4095.0) * 1500);

	    // FR-09: Handle Valve Button Toggle
	    uint8_t current_button_state = HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_0);
	    if (current_button_state == GPIO_PIN_SET && last_button_state == GPIO_PIN_RESET) {
	        coilState = !coilState; // Toggle Coil 0 [cite: 127]
	    }
	    last_button_state = current_button_state;

	    // FR-11: Update Display every 500ms
	    if (HAL_GetTick() - last_lcd_update >= 500) {
	        UpdateDisplay();
	        last_lcd_update = HAL_GetTick();
	    }

	    // FR-05/06/07: Modbus RTU Processing
	    uint8_t rxbuffer[8];
	    if (HAL_UART_Receive(&huart1, rxbuffer, 8, 10) == HAL_OK) {
	        Modbus_ProcessRequest(rxbuffer, 8); // Validates CRC and Responds [cite: 127]
	    }
	  /* USER CODE END 3 */
}

