/**
 * @brief  The application entry point.
 * @retval int
 */
int main(void)
{

	/* USER CODE BEGIN 1 */

	/* USER CODE END 1 */

	/* MCU Configuration--------------------------------------------------------*/

	/* Reset of all peripherals, Initializes the Flash interface and the Systick. */
	HAL_Init();

	/* USER CODE BEGIN Init */

	/* USER CODE END Init */

	/* Configure the system clock */
	SystemClock_Config();

	/* USER CODE BEGIN SysInit */

	/* USER CODE END SysInit */

	/* Initialize all configured peripherals */
	MX_GPIO_Init();
	MX_ADC1_Init();
	/* USER CODE BEGIN 2 */
	MX_USART1_UART_Init();
	MX_I2C1_Init();
	LCD_Init();
	holdingRegisters[REG_HI_ALARM_P] = 3600; // 360 bar
	holdingRegisters[REG_HI_ALARM_F] = 900;  // 900 L/min
	holdingRegisters[REG_HI_ALARM_T] = 1200; // 120°C
	/* USER CODE END 2 */

	/* Infinite loop */
	/* USER CODE BEGIN WHILE */
	while (1)
	{
		/* USER CODE END WHILE */

		/* USER CODE BEGIN 3 */
		holdingRegisters[REG_PRESSURE] = Read_ADC(&hadc1, ADC_CHANNEL_0); //PA0
		holdingRegisters[REG_FLOW] = Read_ADC(&hadc1, ADC_CHANNEL_1); //PA1
		holdingRegisters[REG_TEMP] = Read_ADC(&hadc1, ADC_CHANNEL_2); //PA2

		//updating display
		UpdateDisplay();

		// Modbus request checking
		uint8_t rxbuffer[256];
		uint8_t rxLength = HAL_UART_Receive(&huart1, rxbuffer, sizeof(rxbuffer), 10);
		if(rxLength>0){
			Modbus_ProcessRequest(rxbuffer, rxLength);
		}
		HAL_Delay(10);
	}
	/* USER CODE END 3 */
}

